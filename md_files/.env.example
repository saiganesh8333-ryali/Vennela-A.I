# ==========================================
# VENNELA AI CONFIGURATION
# ==========================================

# Firebase Configuration
# Render/local can use either FIREBASE_CREDENTIALS_JSON or the separate fields below.
# Optional legacy fallback: FIREBASE_CREDENTIALS can point to a local key file.
FIREBASE_CREDENTIALS=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_ENABLED=true
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_UNIVERSE_DOMAIN=googleapis.com

# AI Provider Keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
AI_TEMPERATURE=0.7
AI_TIMEOUT_SECONDS=30

# System Prompt
VENNELA_PROMPT=You are Vennela, a helpful AI assistant with semantic memory. You remember important details about users and provide personalized, contextual responses. Be friendly, thoughtful, and always try to understand the user's underlying needs.

# API Configuration
PORT=8000
RECENT_CHAT_LIMIT=20
MAX_MESSAGE_LENGTH=5000
AI_UNAVAILABLE_REPLY=AI temporarily unavailable. Please try again in a moment.

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1

# Logging
LOG_LEVEL=INFO

# ==========================================
# SETUP INSTRUCTIONS
# ==========================================
# 1. Rename this file to .env
# 2. Fill in your API keys:
#    - GROQ_API_KEY: Get from https://console.groq.com
#    - OPENROUTER_API_KEY: Get from https://openrouter.ai
# 3. Render/local: paste service-account JSON into FIREBASE_CREDENTIALS_JSON
#    OR set the separate FIREBASE_* fields above.
# 4. Run: pip install -r requirements.txt
# 5. Run: uvicorn main:app --reload
