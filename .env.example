# ==========================================
# VENNELA AI CONFIGURATION
# ==========================================

# Firebase Configuration
# Local development can use FIREBASE_CREDENTIALS.
# Render should use FIREBASE_CREDENTIALS_JSON with the full service-account JSON.
FIREBASE_CREDENTIALS=vennela-firebase-key.json
FIREBASE_CREDENTIALS_JSON=

# AI Provider Keys
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# System Prompt
VENNELA_PROMPT=You are Vennela, a helpful AI assistant with semantic memory. You remember important details about users and provide personalized, contextual responses. Be friendly, thoughtful, and always try to understand the user's underlying needs.

# API Configuration
PORT=8000
RECENT_CHAT_LIMIT=20
MAX_MESSAGE_LENGTH=5000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1

# Logging
LOG_LEVEL=INFO

# ==========================================
# SETUP INSTRUCTIONS
# ==========================================
# 1. Rename this file to .env
# 2. Fill in your API keys:
#    - GROQ_API_KEY: Get from https://console.groq.com
#    - OPENROUTER_API_KEY: Get from https://openrouter.ai
# 3. Local: place vennela-firebase-key.json in project root
# 4. Render: paste service-account JSON into FIREBASE_CREDENTIALS_JSON
# 5. Run: pip install -r requirements.txt
# 6. Run: uvicorn main:app --reload
